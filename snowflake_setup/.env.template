# Snowflake credentials for Spider2-Lite SF subset.
# Copy this file to `snowflake_setup/.env` and fill in values from your friend.
# DO NOT COMMIT `.env` (already in snowflake_setup/.gitignore).
#
# Field reference:
#   SNOWFLAKE_ACCOUNT    — account locator, e.g. "abc12345.us-east-1" or "AB12345"
#                          (look at the URL: https://<ACCOUNT>.snowflakecomputing.com)
#   SNOWFLAKE_USER       — service-account username (avoid personal SSO accounts)
#   SNOWFLAKE_PASSWORD   — password for service account (or leave blank if using key-pair)
#   SNOWFLAKE_PRIVATE_KEY_PATH — absolute path to RSA private key (preferred over password
#                          when MFA/SSO is enforced on the parent account)
#   SNOWFLAKE_PRIVATE_KEY_PASSPHRASE — only if the key is encrypted
#   SNOWFLAKE_ROLE       — role that has SELECT on the Spider2 datasets, e.g. SPIDER2_RW
#   SNOWFLAKE_WAREHOUSE  — compute warehouse to use, e.g. SPIDER2_WH (size XS suffices)
#   SNOWFLAKE_DATABASE   — default database; many SF Spider2 items reference DB explicitly,
#                          but the connector still requires a default
#   SNOWFLAKE_SCHEMA     — default schema (usually PUBLIC inside the chosen DB)
#   SNOWFLAKE_REGION     — optional, only required for older account locator formats
#   SNOWFLAKE_QUERY_TAG  — optional tag for billing audit ("spider2-lite-smoke")
#   SNOWFLAKE_AUTHENTICATOR — leave blank for password auth; set to
#                            "snowflake_jwt" for key-pair, or "externalbrowser" for SSO
#                            (last one is interactive — NOT suitable for runners)

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_REGION=
SNOWFLAKE_QUERY_TAG=spider2-lite-smoke
SNOWFLAKE_AUTHENTICATOR=

+++ b/models/agg/monthly_agg_reviews.sql
@@ -1,6 +1,18 @@
 {{
     config(
         materialized="incremental",
         alias="monthly_agg_reviews",
         schema="main",
         unique_key="DATE_SENTIMENT_ID"
     )
+    , tags=["daily", "month_over_month"]
 }}
 
 WITH review_cte AS (
     SELECT *
     FROM {{ref('fct_reviews')}}
+),
+listings_cte AS (
+    SELECT ID, NAME, HOST_ID
+    FROM {{source('airbnb', 'RAW_LISTINGS')}}
+),
+hosts_cte AS (
+    SELECT ID, NAME
+    FROM {{source('airbnb', 'RAW_HOSTS')}}
 )
 
 SELECT
     COUNT(*) AS REVIEW_TOTALS,
     REVIEW_SENTIMENT,
     STRFTIME('%m-%Y', REVIEW_DATE) AS MONTH_YEAR,
     EXTRACT(MONTH FROM REVIEW_DATE) AS MONTH,
     EXTRACT(YEAR FROM REVIEW_DATE) AS YEAR,
     {{dbt_utils.surrogate_key(['CAST(EXTRACT(MONTH FROM REVIEW_DATE) AS TEXT)',
                                'CAST(EXTRACT(YEAR FROM REVIEW_DATE) AS TEXT)',
                                'REVIEW_SENTIMENT'])}} AS DATE_SENTIMENT_ID,
+    listings_cte.NAME AS LISTING_NAME,
+    hosts_cte.NAME AS HOST_NAME
 FROM review_cte
+LEFT JOIN listings_cte ON review_cte.LISTING_ID = listings_cte.ID
+LEFT JOIN hosts_cte ON listings_cte.HOST_ID = hosts_cte.ID
 {% if is_incremental() %}
 WHERE 
     EXTRACT(MONTH FROM REVIEW_DATE) = EXTRACT(MONTH FROM CURRENT_DATE)
     AND EXTRACT(YEAR FROM REVIEW_DATE) = EXTRACT(YEAR FROM CURRENT_DATE)
 {% endif %}
 
 GROUP BY
     REVIEW_SENTIMENT,
     MONTH_YEAR,
     MONTH,
     YEAR,
     DATE_SENTIMENT_ID,
+    LISTING_NAME,
+    HOST_NAME
 ORDER BY
     YEAR DESC,
     MONTH DESC

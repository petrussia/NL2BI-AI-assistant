# Agent / IDE local state
.claude/

# Ephemeral notebook tooling output
notebooks/PowerShell tool output*.txt

# External benchmark raw clones / zips — large and reproducible from manifests in
# external_benchmarks/*/manifests/. The processed slices live in
# external_benchmarks/*/processed/ and ARE committed.
external_benchmarks/*/raw/

# Python cache
__pycache__/
*.pyc
*.pyo

# OS noise
.DS_Store
Thumbs.db

# Secrets / credentials — NEVER commit
snowflake_setup/.env
**/*sa.json
**/*service_account*.json
**/secrets/

# Ephemeral bridge URLs (change per Cloudflare quick-tunnel session)
tools/.bridge_url
tools/.bridge_url_dbt
tools/.bridge_url_lite

# Backup tarballs — regenerable
tools/backups/

# Old export bundles superseded by outputs/final/
outputs/final.zip
outputs/final (2).zip
outputs/exports/joint_vkr_export_pack_v10.tar.gz
outputs/joint_vkr_export_pack_v10/
outputs/thesis_pack_shubin_v10/

# Raw downloaded benchmark data + lazy-pulled schema cache
data/spider2_lite/raw/
data/spider2_lite/resource/
data/spider2_snow/raw/
data/spider2_snow/resource/

# Scratch dumps
_all_68.txt

# DBT task workspace staging — materialised at run time, ephemeral
data/spider2_dbt/tasks/*/workspace_staging/

# Local logs / temp files
outputs/spider2_snow/_*.log
outputs/spider2_lite/_*.log
outputs/spider2_dbt/_*.log

# Phase 18 large live-catalog jsonls — regenerable via tools/harvest_*_v18.py.
# Logs and audit md ARE committed.
outputs/cache/spider2_bq_live_catalog_v18.jsonl
outputs/cache/spider2_snow_live_catalog_v18.jsonl
outputs/cache/_*_HARVEST_*
outputs/cache/_v18_*.log

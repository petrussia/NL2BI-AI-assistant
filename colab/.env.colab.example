# Tunnel + git auth (Drive .env on Colab)
NGROK_AUTHTOKEN=your-ngrok-token-here
GITHUB_PAT=ghp_your_github_pat_with_repo_read_scope

# Auth + feature flags for the Colab Text-to-SQL FastAPI service.
# COLAB_API_TOKEN can also live at /content/drive/MyDrive/.colab_api_token
# (Drive fallback exists because the claude.ai Drive MCP can only write
# at MyDrive root, not into nested folders).
COLAB_API_TOKEN=your-shared-bearer-token

# When true, /extract and /reload_model require Authorization: Bearer <token>.
COLAB_REQUIRE_AUTH=true

# When false (default), /debug/datasources returns 404.
# When true, /debug/datasources is enabled AND requires auth.
COLAB_DEBUG_ENDPOINTS=false

# When false (default), /admin/bridge_url returns 404.
# When true, /admin/bridge_url is enabled AND requires auth.
COLAB_BRIDGE_ENABLED=false

# Bridge auth — fail-closed: if BRIDGE_TOKEN is not set (env or Drive
# fallback file /content/drive/MyDrive/.bridge_token), agent_bridge refuses
# to start and /exec rejects all requests.
BRIDGE_TOKEN=your-bridge-token

# Model + runtime
COLAB_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct
COLAB_QUANTIZATION=4bit
COLAB_MAX_NEW_TOKENS=512
COLAB_MOCK_MODEL=false
COLAB_PORT=8000

# Data
COLAB_SPIDER_DB_ROOT=/content/drive/MyDrive/diploma_plan_sql/data/spider/database
COLAB_DATA_SOURCES_PATH=/content/nl2bi-colab/demo_data/data_sources.json
COLAB_DEFAULT_DATA_SOURCE_ID=demo_concert_singer

# Logs / artifacts on Drive
COLAB_ARTIFACTS_DIR=/content/drive/MyDrive/nl2bi_colab/artifacts
COLAB_LOG_DIR=/content/drive/MyDrive/nl2bi_colab/logs

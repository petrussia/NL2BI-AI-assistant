{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan_schema_v2",
  "title": "Compact NL→SQL Plan v2",
  "description": "Compact plan for B2_v3 / B4_v3. Drops historical optional fields to keep the planner prompt small.",
  "type": "object",
  "additionalProperties": false,
  "required": ["intent", "tables", "operations"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["select_count", "select_aggregate", "select_filter",
               "select_join", "select_groupby", "select_orderby", "select_other"]
    },
    "tables": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 20},
    "operations": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 12},
    "columns": {"type": "array", "items": {"type": "string"}},
    "filters": {"type": "array", "items": {"type": "object"}},
    "aggregations": {"type": "array", "items": {"type": "string"}},
    "group_by": {"type": "array", "items": {"type": "string"}},
    "order_by": {"type": "array", "items": {"type": "string"}},
    "limit": {"type": ["integer", "null"]},
    "joins": {"type": "array", "items": {"type": "object"}},
    "distinct": {"type": "boolean"},
    "answer_shape": {
      "type": "string",
      "enum": ["scalar", "row", "table", "unknown"]
    },
    "expected_card": {
      "type": "string",
      "enum": ["one", "few", "many", "unknown"]
    },
    "evidence_used": {"type": "boolean"},
    "notes": {"type": "string"}
  }
}
